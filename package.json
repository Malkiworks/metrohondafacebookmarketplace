{
  "name": "metro-honda-marketplace",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c blue,green \"python -m metro_fb.server\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "python -m metro_fb.server --host 0.0.0.0 --port 10000",
    "data": "python -m metro_fb export-web",
    "scrape": "python -m metro_fb scrape",
    "refresh": "python -m metro_fb scrape && python -m metro_fb export-web"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
